<launch>
    <arg name="rviz" default="true" />
    <arg name="publish_sliced_pointcloud" default="true" />
    <arg name="enable_integrated_leveler" default="false" />
    <arg name="leveler_output_topic" default="/merged_pointcloud_leveled" />
    <arg name="leveler_livox_custom_output_topic" default="/merged_livox_leveled" />
    <arg name="leveler_imu_output_topic" default="/merged_imu_leveled" />
    <arg name="leveler_source_frame_id" default="body" />
    <arg name="leveler_output_frame_id" default="body_leveled" />
    <arg name="leveler_calib_duration_sec" default="2.0" />
    <arg name="leveler_min_imu_samples" default="800" />
    <arg name="leveler_calib_max_gyro_norm_rad_s" default="0.2" />
    <arg name="leveler_calib_acc_norm_tolerance_ratio" default="0.15" />
    <arg name="leveler_calib_acc_norm_gate_warmup_samples" default="50" />
    <arg name="leveler_publish_before_calibrated" default="false" />
    <arg name="leveler_publish_level_tf" default="true" />

    <!-- Multi-LiDAR and IMU Fusion Node for Livox Sensors -->
    <node pkg="livox_merge" type="merge_lidar_node" name="livox_merge_node" output="screen">
        
        <!-- 从配置文件加载参数，键名与代码匹配 -->
        <rosparam file="$(find livox_merge)/config/livox_merge_config.yaml" command="load" />

         <!-- Height slicing parameters -->
        <param name="slice_z_min" value="-1.5"/>
        <param name="slice_z_max" value="2.5"/>
        <param name="publish_sliced_pointcloud" value="$(arg publish_sliced_pointcloud)"/>
        <param name="enable_integrated_leveler" value="$(arg enable_integrated_leveler)"/>
        <param name="leveler_output_topic" value="$(arg leveler_output_topic)"/>
        <param name="leveler_livox_custom_output_topic" value="$(arg leveler_livox_custom_output_topic)"/>
        <param name="leveler_imu_output_topic" value="$(arg leveler_imu_output_topic)"/>
        <param name="leveler_source_frame_id" value="$(arg leveler_source_frame_id)"/>
        <param name="leveler_output_frame_id" value="$(arg leveler_output_frame_id)"/>
        <param name="leveler_calib_duration_sec" value="$(arg leveler_calib_duration_sec)"/>
        <param name="leveler_min_imu_samples" value="$(arg leveler_min_imu_samples)"/>
        <param name="leveler_calib_max_gyro_norm_rad_s" value="$(arg leveler_calib_max_gyro_norm_rad_s)"/>
        <param name="leveler_calib_acc_norm_tolerance_ratio" value="$(arg leveler_calib_acc_norm_tolerance_ratio)"/>
        <param name="leveler_calib_acc_norm_gate_warmup_samples" value="$(arg leveler_calib_acc_norm_gate_warmup_samples)"/>
        <param name="leveler_publish_before_calibrated" value="$(arg leveler_publish_before_calibrated)"/>
        <param name="leveler_publish_level_tf" value="$(arg leveler_publish_level_tf)"/>
        
        <!-- Topic Remapping -->
        <remap from="/merged_pointcloud" to="/merged_pointcloud"/>
        <remap from="/merged_pointcloud_sliced" to="/merged_pointcloud_sliced"/>
        <remap from="/merged_livox" to="/merged_livox"/>
        <remap from="/merged_imu" to="/merged_imu"/>
    </node>

    <!-- RViz Visualization -->
        <node name="rviz" pkg="rviz" type="rviz" output="screen"
            if="$(arg rviz)"
            args="-d $(find livox_merge)/rviz/livox_merge.rviz"/>

    <!-- System Monitoring -->
    <!-- <node name="fusion_monitor" pkg="livox_merge" type="test_fusion_system.py" output="screen"/> -->
    
</launch>