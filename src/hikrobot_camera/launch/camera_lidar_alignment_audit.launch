<launch>
  <arg name="image_topic" default="/hikrobot_camera/rgb/leveled/compressed" />
  <arg name="pointcloud_topic" default="/merged_pointcloud_leveled" />
  <arg name="source_frame" default="hikrobot_camera" />
  <arg name="parent_frame" default="body_leveled" />
  <arg name="output_frame" default="hikrobot_camera_leveled" />
  <arg name="expected_reference_frame" default="$(arg parent_frame)" />
  <arg name="message_timeout_sec" default="5.0" />
  <arg name="tf_timeout_sec" default="5.0" />
  <arg name="translation_warn_threshold_m" default="5.0" />

  <node pkg="hikrobot_camera"
        type="check_camera_lidar_alignment.py"
        name="camera_lidar_alignment_audit"
        output="screen">
    <param name="image_topic" value="$(arg image_topic)" />
    <param name="pointcloud_topic" value="$(arg pointcloud_topic)" />
    <param name="source_frame" value="$(arg source_frame)" />
    <param name="parent_frame" value="$(arg parent_frame)" />
    <param name="output_frame" value="$(arg output_frame)" />
    <param name="expected_reference_frame" value="$(arg expected_reference_frame)" />
    <param name="message_timeout_sec" value="$(arg message_timeout_sec)" />
    <param name="tf_timeout_sec" value="$(arg tf_timeout_sec)" />
    <param name="translation_warn_threshold_m" value="$(arg translation_warn_threshold_m)" />
  </node>
</launch>