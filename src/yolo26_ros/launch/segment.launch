<launch>
    <arg name="topic_img" default="/hikrobot_camera/rgb" />
    <arg name="topic_pointcloud" default="/livox/lidar" />
    <arg name="topic_res_img" default="/segment/image_raw" />
    <arg name="topic_res_img_pc" default="/segment/topic_res_img_pc_" />
    <arg name="weight_name" default="yolo26s-seg.engine" />
    <arg name="topic_object_states" default="/segment/object_states" />
    <arg name="projection_config_path" default="$(find yolo26_ros)/config/segment_projection.yaml" />
    <arg name="flip_lidar_y_for_projection" default="false" />
    <arg name="use_tf_for_projection" default="true" />
    <arg name="log_rotated_grid" default="false" />
    <arg name="tf_lookup_timeout_sec" default="0.02" />
    <arg name="sync_max_interval_sec" default="0.12" />
    <arg name="enable_pointcloud_downsample" default="false" />
    <arg name="pointcloud_leaf_size_m" default="0.03" />

    <param name="topic_img" type="string" value="$(arg topic_img)" />
    <param name="topic_pointcloud" type="string" value="$(arg topic_pointcloud)" />
    <param name="topic_res_img" type="string" value="$(arg topic_res_img)" />
    <param name="topic_res_img_pc_" type="string" value="$(arg topic_res_img_pc)" />
    <param name="weight_name" type="string" value="$(arg weight_name)" />
    <param name="topic_object_states" type="string" value="$(arg topic_object_states)" />
    <param name="projection_config_path" type="string" value="$(arg projection_config_path)" />
    <param name="flip_lidar_y_for_projection" type="bool" value="$(arg flip_lidar_y_for_projection)" />
    <param name="use_tf_for_projection" type="bool" value="$(arg use_tf_for_projection)" />
    <param name="log_rotated_grid" type="bool" value="$(arg log_rotated_grid)" />
    <param name="tf_lookup_timeout_sec" type="double" value="$(arg tf_lookup_timeout_sec)" />
    <param name="sync_max_interval_sec" type="double" value="$(arg sync_max_interval_sec)" />
    <param name="enable_pointcloud_downsample" type="bool" value="$(arg enable_pointcloud_downsample)" />
    <param name="pointcloud_leaf_size_m" type="double" value="$(arg pointcloud_leaf_size_m)" />

    <node pkg="yolo26_ros" name="segment" type="segment" output="screen" />
</launch>
